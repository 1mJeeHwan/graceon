# Deploy env example — copy to `.env` on the VM (next to docker-compose.yml).
# `.env` is gitignored (**/.env); NEVER commit the real Kakao key (public repo).
# docker compose auto-loads `.env` from the project root, feeding the ${...} refs
# in docker-compose.deploy.yml.

# --- 교회찾기(C1): 내 주변 실제 교회 ---
# discovery=kakao → 내 주변 실제 교회(카카오 POI)를 DB 결과에 병합
# geocode=kakao   → 관리자 등록 교회 주소를 실제 좌표로 변환
CHURCH_DISCOVERY_PROVIDER=kakao
CHURCH_GEOCODE_PROVIDER=kakao
# 카카오 Developers → 내 앱 → REST API 키 (지도 JS 키 아님)
CHURCH_GEOCODE_KAKAO_REST_KEY=여기에_카카오_REST_키

# --- 챗봇(C5): Gemini LLM (선택) ---
# provider=llm + 키 주입 시 자연어 LLM 응답. 미설정/실패 시 rule(키워드) 로 자동 폴백.
# 무료 티어 키: Google AI Studio(ai.google.dev) → Get API key (카드 불필요, AIza... 로 시작).
# 안 켜려면 아래 3줄을 비워두거나 지우면 됨(기본 rule).
# CHAT_PROVIDER=llm
# CHAT_LLM_API_KEY=여기에_Gemini_API_키
# CHAT_LLM_MODEL=gemini-2.5-flash

# --- 기타 운영값 (필요 시) ---
# JWT_SECRET=...                       # openssl rand -base64 48
# APP_CORS_ALLOWED_ORIGINS=https://<admin>.vercel.app,https://<userweb>.vercel.app
# PAYMENT_RETURN_BASE_URL=https://<userweb>.vercel.app
