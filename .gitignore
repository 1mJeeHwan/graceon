# macOS
.DS_Store

# IDE
.idea/
*.iml
.vscode/

# Java / Maven (any subproject)
**/target/
*.class

# Node / Next.js (any subproject)
**/node_modules/
**/.next/
**/out/
**/build/
*.tsbuildinfo
